{
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    }
  ],
  "routes": [
    { "src": "/css/(.*)",      "dest": "/css/$1"      },
    { "src": "/js/(.*)",       "dest": "/js/$1"        },
    { "src": "/firebase/(.*)", "dest": "/firebase/$1"  },
    { "src": "/(.*\\.json)",   "dest": "/$1"           },
    { "src": "/(.*)",          "dest": "/index.html"   }
  ]
}
